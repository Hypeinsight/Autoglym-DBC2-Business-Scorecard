# ============================================================
# Autoglym DBC2 Business Scorecard — environment template
# Copy to .env.local and fill in. Never commit real credentials.
# Phase 2 (backend/API) consumes these; the Phase 1 wireframe runs
# entirely on sample data and needs none of them.
# ============================================================

# Base URL of the backend data API (Node.js service, Phase 2)
VITE_API_BASE_URL=http://localhost:3000/api

# Google Analytics 4 — sessions, engagement, page conversion, avg session duration
VITE_GA4_PROPERTY_ID=

# Google Ads — spend, impressions, ROAS, CTR
VITE_GOOGLE_ADS_CUSTOMER_ID=

# Iconosquare — organic social impressions, engagements, CTR
VITE_ICONOSQUARE_PROFILE_ID=
