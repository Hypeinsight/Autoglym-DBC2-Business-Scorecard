# ============================================================
# Autoglym DBC2 Scorecard — Server environment template
# Copy to .env and fill in. Never commit real credentials.
# ============================================================

PORT=3001

# ── Google Analytics 4 ──────────────────────────────────────
# Service account JSON key (downloaded from Google Cloud Console).
# The service account must have "Viewer" access on the GA4 property.
GA4_KEY_FILE=./credentials/ga4-service-account.json
# GA4 Property ID (numeric, e.g. 123456789 — NOT the measurement ID UA-xxx)
GA4_PROPERTY_ID=

# ── Google Ads ───────────────────────────────────────────────
# OAuth2 credentials — generate via Google Ads API Center
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
# Manager (MCC) customer ID if applicable (without hyphens, e.g. 1234567890)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# The specific customer account to report on
GOOGLE_ADS_CUSTOMER_ID=

# ── Meta Ads (Facebook / Instagram) ─────────────────────────
# System User access token — never expires (preferred over page tokens).
# Generate in Meta Business Suite → Business Settings → System Users.
# Required permissions: ads_read, business_management
META_ACCESS_TOKEN=
# Ad Account ID (numeric). You can prefix with act_ or leave it bare.
META_AD_ACCOUNT_ID=

# ── Meta Organic (Facebook Page + Instagram) — replaces Iconosquare ────
# Same System User token as above, but needs additional Page/IG assets +
# permissions added in Business Settings: pages_read_engagement,
# pages_show_list, instagram_basic, instagram_manage_insights.
# Facebook Page ID (Business Settings → Accounts → Pages)
META_PAGE_ID=
# Instagram Business Account ID linked to the Page
META_IG_ACCOUNT_ID=

# ── Klaviyo ──────────────────────────────────────────────────
# Private API key — found in Klaviyo → Account → Settings → API Keys
KLAVIYO_API_KEY=
# Klaviyo list ID for the main Autoglym subscriber list
KLAVIYO_LIST_ID=

# ── Frontend (Vite) ──────────────────────────────────────────
# The Vite app proxies /api to this origin in dev (set in vite.config.ts).
# In production, point the frontend to wherever this server is hosted.
FRONTEND_ORIGIN=http://localhost:5173
